#!/usr/bin/env bash
#
# docker-run — run any command inside the gtkx CI container.
#
# The container image (gtkx-ci:local, built from .github/docker) carries every
# GTK/Adwaita build and runtime dependency, so commands behave identically to
# CI regardless of the host distribution. The repository is mounted at
# /workspace and the caller's working directory is mirrored inside it.
#
# Under Podman the container runs as the host user (keep-id), so a forwarded
# Wayland session, D-Bus, and the accessibility bus all authenticate, and GUI
# commands such as `gtkx dev` display on the host compositor.
#
# Usage:
#   scripts/docker-run [command [args...]]
#
# With no command an interactive shell is opened. Environment overrides:
#   CONTAINER_ENGINE   podman | docker   (auto-detected)
#   GTKX_CI_IMAGE      image tag         (default gtkx-ci:local)

set -euo pipefail

IMAGE="${GTKX_CI_IMAGE:-gtkx-ci:local}"
RUN_ARGS=()

select_engine() {
    if [ -n "${CONTAINER_ENGINE:-}" ]; then
        printf '%s' "$CONTAINER_ENGINE"
    elif command -v podman >/dev/null 2>&1; then
        printf 'podman'
    elif command -v docker >/dev/null 2>&1; then
        printf 'docker'
    else
        echo "docker-run: podman or docker is required" >&2
        exit 1
    fi
}

repo_root() {
    dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
}

ensure_image() {
    local engine="$1" root="$2"
    if ! "$engine" image inspect "$IMAGE" >/dev/null 2>&1; then
        echo "docker-run: building $IMAGE (first run, this is slow) ..." >&2
        "$engine" build -t "$IMAGE" "$root/.github/docker"
    fi
}

container_workdir() {
    local root="$1" rel
    rel="$(realpath --relative-to="$root" "$PWD" 2>/dev/null || echo .)"
    case "$rel" in
        .|..*|/*) printf '/workspace' ;;
        *) printf '/workspace/%s' "$rel" ;;
    esac
}

add_wayland_args() {
    local runtime_dir socket display
    runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    display="${WAYLAND_DISPLAY:-wayland-0}"
    case "$display" in
        /*) socket="$display" ;;
        *) socket="$runtime_dir/$display" ;;
    esac
    if [ ! -S "$socket" ]; then
        return 0
    fi
    RUN_ARGS+=(
        -v "$runtime_dir:$runtime_dir"
        -e "XDG_RUNTIME_DIR=$runtime_dir"
        -e "WAYLAND_DISPLAY=$display"
        -e GDK_BACKEND=wayland
        -e LIBGL_ALWAYS_SOFTWARE=1
    )
}

add_engine_args() {
    local engine="$1"
    if [ "$engine" = podman ]; then
        RUN_ARGS+=(--userns=keep-id -e HOME=/tmp)
    fi
}

main() {
    local engine root
    engine="$(select_engine)"
    root="$(repo_root)"
    ensure_image "$engine" "$root"

    RUN_ARGS=(--rm -e CI=true -v "$root:/workspace" -w "$(container_workdir "$root")")
    add_engine_args "$engine"
    if [ -t 0 ]; then
        RUN_ARGS+=(-it)
    fi
    add_wayland_args

    if [ "$#" -eq 0 ]; then
        set -- bash
    fi
    exec "$engine" run "${RUN_ARGS[@]}" "$IMAGE" "$@"
}

main "$@"
