{
    "$schema": "https://turborepo.com/schema.json",
    "globalDependencies": [
        "tsconfig.base.json",
        "tsconfig.lib.json",
        "tsconfig.test.json",
        "biome.json",
        "vitest.config.ts"
    ],
    "globalEnv": ["NODE_VERSION", "GTK4_VERSION", "VERSION"],
    "globalPassThroughEnv": [
        "TURBO_TOKEN",
        "TURBO_TEAM",
        "DISPLAY",
        "WAYLAND_DISPLAY",
        "XDG_RUNTIME_DIR",
        "XAUTHORITY",
        "DBUS_SESSION_BUS_ADDRESS",
        "GDK_BACKEND",
        "GDK_DISABLE",
        "GSK_RENDERER",
        "LIBGL_ALWAYS_SOFTWARE"
    ],
    "tasks": {
        // Knip resolves cross-package imports through each package's `exports`
        // field (which points into `dist/`); without these build dependencies,
        // knip reports false-positive "unused dependency" findings for any
        // workspace consumer that imports from a sibling package. New packages
        // must be added here, or they silently drop out of the build chain.
        "//#lint:all": {
            "dependsOn": [
                "@gtkx/cli#build",
                "@gtkx/codegen#build",
                "@gtkx/css#build",
                "@gtkx/ffi#build",
                "@gtkx/mcp#build",
                "@gtkx/native#build",
                "@gtkx/react#build",
                "@gtkx/testing#build",
                "@gtkx/vitest#build"
            ],
            "inputs": ["**/*.ts", "**/*.tsx", "**/package.json", "biome.json", "knip.json"],
            "outputLogs": "new-only"
        },
        "lint": {
            "inputs": ["Cargo.toml", "Cargo.lock", "build.rs", "src/**/*.rs", "tests/**/*.rs"],
            "outputs": [],
            "outputLogs": "new-only",
            "passThroughEnv": ["RUSTUP_TOOLCHAIN"]
        },
        "build": {
            "dependsOn": ["^build", "native-build"],
            "inputs": [
                "package.json",
                "*.ts",
                "bin/**",
                "src/**/*.ts",
                "src/**/*.tsx",
                "tsconfig.json",
                "tsconfig.app.json",
                "tsconfig.lib.json",
                "tsconfig.test.json"
            ],
            "outputs": ["dist/**", "out-tsc/**", "*.tsbuildinfo"],
            "outputLogs": "new-only"
        },
        "native-build": {
            "inputs": ["Cargo.toml", "Cargo.lock", "build.rs", "src/**/*.rs"],
            "outputs": [
                "*.node",
                "native-binding.cjs",
                "native-binding.d.cts",
                "npm/linux-arm64-gnu/*.node",
                "npm/linux-x64-gnu/*.node"
            ],
            "outputLogs": "new-only",
            "passThroughEnv": ["RUSTUP_TOOLCHAIN", "CARGO_INCREMENTAL", "CARGO_NET_RETRY"]
        },
        "native-test": {
            "dependsOn": ["native-build"],
            "inputs": ["Cargo.toml", "src/**/*.rs"],
            "outputs": [],
            "outputLogs": "new-only",
            "passThroughEnv": ["RUSTUP_TOOLCHAIN"]
        },
        "start": {
            "dependsOn": ["build"],
            "persistent": true,
            "cache": false
        },
        "dev": {
            "dependsOn": ["^build"],
            "persistent": true,
            "cache": false
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "inputs": [
                "src/**/*.ts",
                "src/**/*.tsx",
                "tsconfig.json",
                "tsconfig.app.json",
                "tsconfig.lib.json",
                "tsconfig.test.json"
            ],
            "outputs": [],
            "outputLogs": "new-only"
        },
        "test": {
            "dependsOn": ["^build", "native-test"],
            "inputs": ["vitest.config.ts", "src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
            "outputLogs": "new-only"
        },
        "coverage": {
            "dependsOn": ["^build", "native-coverage"],
            "inputs": ["vitest.config.ts", "src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
            "outputs": ["coverage/**"],
            "outputLogs": "new-only"
        },
        "native-coverage": {
            "dependsOn": ["native-build"],
            "inputs": ["Cargo.toml", "src/**/*.rs", "tests/**/*.rs"],
            "outputs": ["coverage/**"],
            "outputLogs": "new-only",
            "passThroughEnv": ["RUSTUP_TOOLCHAIN"]
        },
        "@gtkx/ffi#conformance": {
            "inputs": ["src/**/*.ts", "src/generated/**/*.js", "src/generated/**/*.d.ts", "scripts/conformance.ts"],
            "outputs": [],
            "outputLogs": "new-only"
        },
        "@gtkx/native#typecheck": {
            "dependsOn": ["^build", "native-build"],
            "inputs": ["*.ts", "tests/**/*.ts", "tsconfig.json", "tsconfig.lib.json", "tsconfig.test.json"],
            "outputs": [],
            "outputLogs": "new-only"
        },
        "website#build": {
            "dependsOn": ["@gtkx/ffi#build", "@gtkx/react#build"],
            "inputs": [
                "package.json",
                ".vitepress/**",
                "guide/**",
                "index.md",
                "public/**",
                "scripts/**",
                "tsconfig.json"
            ],
            "outputs": [".vitepress/dist/**", "api/**"],
            "outputLogs": "new-only"
        },
        "website#dev": {
            "dependsOn": ["@gtkx/ffi#build", "@gtkx/react#build"],
            "persistent": true,
            "cache": false
        }
    }
}
