{
    "name": "gtkx",
    "version": "0.0.0",
    "private": true,
    "homepage": "https://gtkx.dev",
    "license": "MPL-2.0",
    "author": "Eugenio Depalo <eugeniodepalo@gmail.com>",
    "type": "module",
    "scripts": {
        "build": "turbo build --filter=!website --filter=!gtkx",
        "codegen": "node --conditions=source --import tsx packages/cli/src/cli.ts codegen",
        "conformance": "turbo conformance --filter=@gtkx/ffi",
        "docs": "turbo build --filter=website",
        "circular": "dpdm --no-warning --no-tree --transform -T --skip-dynamic-imports circular --exit-code circular:1 --exclude '(node_modules|dist|generated|out-tsc)' 'packages/{cli,codegen,css,e2e,ffi,mcp,react,testing,vitest}/src/**/*.{ts,tsx}'",
        "knip": "knip",
        "lint": "turbo lint:all && turbo lint --filter=!website --filter=!gtkx",
        "lint:all": "biome check . && knip && pnpm circular",
        "coverage": "turbo coverage --filter=!website --filter=!gtkx --concurrency=1",
        "test": "turbo test --filter=!website --filter=!gtkx --concurrency=1",
        "typecheck": "turbo typecheck --filter=!website --filter=!gtkx"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@types/node": "^25.8.0",
        "@types/react": "^19.2.14",
        "@vitest/coverage-v8": "^4.1.6",
        "dpdm": "^4.2.0",
        "knip": "^6.14.0",
        "react": "^19.2.6",
        "tsx": "^4.22.0",
        "turbo": "^2.9.14",
        "typescript": "^6.0.3",
        "vitest": "^4.1.6"
    },
    "engines": {
        "node": ">=24"
    },
    "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
