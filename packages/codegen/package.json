{
    "name": "@gtkx/codegen",
    "version": "0.0.0",
    "private": true,
    "description": "Code generation tools for GTKX",
    "homepage": "https://gtkx.dev",
    "bugs": {
        "url": "https://github.com/gtkx-org/gtkx/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/gtkx-org/gtkx.git",
        "directory": "packages/codegen"
    },
    "license": "MPL-2.0",
    "author": "Eugenio Depalo <eugeniodepalo@gmail.com>",
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.lib.json",
        "test": "vitest run",
        "coverage": "vitest run --coverage",
        "typecheck": "tsc -b --emitDeclarationOnly"
    },
    "devDependencies": {
        "@clack/prompts": "^1.4.0",
        "@gtkx/native": "workspace:*",
        "@ts-for-gir/cli": "^3.3.0",
        "fast-xml-parser": "^5.7.3"
    }
}
