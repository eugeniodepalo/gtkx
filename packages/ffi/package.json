{
  "name": "@gtkx/ffi",
  "version": "0.1.0",
  "license": "MPL-2.0",
  "author": "Eugenio Depalo <eugeniodepalo@gmail.com>",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "development": "./src/generated/*/index.ts",
      "default": "./dist/generated/*/index.js",
      "types": "./dist/generated/*/index.d.ts"
    }
  },
  "dependencies": {
    "@gtkx/native": "workspace:*"
  },
  "devDependencies": {
    "@gtkx/codegen": "workspace:*"
  },
  "scripts": {
    "build": "tsc -b",
    "codegen": "gtkx-codegen batch /usr/share/gir-1.0 -o ./src/generated"
  }
}
