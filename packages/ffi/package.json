{
  "name": "@gtkx/ffi",
  "version": "0.1.0",
  "license": "MPL-2.0",
  "author": "Eugenio Depalo <eugeniodepalo@gmail.com>",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./codegen": {
      "development": "./src/codegen/index.ts",
      "import": "./dist/codegen/index.js",
      "types": "./dist/codegen/index.d.ts"
    },
    "./*": {
      "development": "./src/generated/*/index.ts",
      "default": "./dist/generated/*/index.js",
      "types": "./dist/generated/*/index.d.ts"
    }
  },
  "dependencies": {
    "@gtkx/native": "workspace:*"
  },
  "devDependencies": {
    "@gtkx/gir": "workspace:*",
    "commander": "14.0.2",
    "prettier": "3.6.2",
    "tsx": "4.20.6"
  },
  "scripts": {
    "build": "tsc -b",
    "codegen": "tsx src/codegen/cli.ts batch /usr/share/gir-1.0 -o ./src/generated"
  }
}
