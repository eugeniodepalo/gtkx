{
    "name": "@gtkx/ffi",
    "version": "0.21.0",
    "description": "Generated TypeScript FFI bindings for GTKX",
    "keywords": [
        "gtkx",
        "gtk",
        "gtk4",
        "ffi",
        "bindings",
        "typescript",
        "linux",
        "desktop"
    ],
    "homepage": "https://gtkx.dev",
    "bugs": {
        "url": "https://github.com/gtkx-org/gtkx/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/gtkx-org/gtkx.git",
        "directory": "packages/ffi"
    },
    "license": "MPL-2.0",
    "author": "Eugenio Depalo <eugeniodepalo@gmail.com>",
    "type": "module",
    "sideEffects": true,
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./gl": {
            "types": "./dist/gl/index.d.ts",
            "default": "./dist/gl/index.js"
        },
        "./cairo": {
            "types": "./dist/cairo/index.d.ts",
            "default": "./dist/cairo/index.js"
        },
        "./gdk": {
            "types": "./dist/gdk/index.d.ts",
            "default": "./dist/gdk/index.js"
        },
        "./gobject": {
            "types": "./dist/gobject/index.d.ts",
            "default": "./dist/gobject/index.js"
        },
        "./graphene": {
            "types": "./dist/graphene/index.d.ts",
            "default": "./dist/graphene/index.js"
        },
        "./gtk": {
            "types": "./dist/gtk/index.d.ts",
            "default": "./dist/gtk/index.js"
        },
        "./*": {
            "types": "./dist/generated/*/*.d.ts",
            "default": "./dist/generated/*/*.js"
        }
    },
    "files": [
        "dist",
        "src",
        "scripts",
        "!dist/generated",
        "!src/generated",
        "!**/*.tsbuildinfo"
    ],
    "scripts": {
        "build": "tsc -b && pnpm run copy-generated-dts",
        "copy-generated-dts": "node scripts/copy-generated-dts.ts",
        "conformance": "node scripts/conformance.ts",
        "postinstall": "node scripts/postinstall.ts",
        "test": "vitest run",
        "coverage": "vitest run --coverage",
        "typecheck": "tsc -b --emitDeclarationOnly && pnpm run copy-generated-dts"
    },
    "engines": {
        "node": ">=24"
    },
    "dependencies": {
        "@gtkx/native": "workspace:*"
    },
    "devDependencies": {
        "@gtkx/vitest": "workspace:*"
    }
}
