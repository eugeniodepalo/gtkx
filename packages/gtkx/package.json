{
	"name": "@gtkx/gtkx",
	"version": "0.1.0",
	"license": "MPL-2.0",
	"author": "Eugenio Depalo <eugeniodepalo@gmail.com>",
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"development": "./src/index.ts",
			"default": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./jsx": {
			"development": "./src/generated/jsx.ts",
			"default": "./dist/generated/jsx.js",
			"types": "./dist/generated/jsx.d.ts"
		}
	},
	"dependencies": {
		"@gtkx/ffi": "workspace:*",
		"react": "19.2.0",
		"react-reconciler": "0.33.0"
	},
	"devDependencies": {
		"@gtkx/gir": "workspace:*",
		"@types/react": "19.2.6",
		"@types/react-reconciler": "0.32.3",
		"commander": "14.0.2",
		"prettier": "3.6.2",
		"tsx": "4.20.6"
	},
	"scripts": {
		"build": "tsc -b",
		"codegen": "tsx src/codegen/cli.ts generate /usr/share/gir-1.0/Gtk-4.0.gir -o ./src/generated/jsx.ts",
		"example": "tsx --conditions=development src/example.tsx"
	}
}
